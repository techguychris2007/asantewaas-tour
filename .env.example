# Supabase — get these from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose this. Used by the admin page.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Simple password for the admin (bookings) page. Pick a strong one.
ADMIN_PASSWORD=change-me-to-something-strong

# Public site URL (used for absolute links; set to your Vercel URL after deploy)
NEXT_PUBLIC_SITE_URL=https://asantewaastour.com
